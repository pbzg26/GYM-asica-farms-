rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol
          in ['admin', 'superadmin'];
    }

    // ── Usuarios ─────────────────────────────────────────────────
    match /usuarios/{uid} {
      // El propio usuario puede leer/crear/editar su doc
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Subcollections privadas del usuario
      match /historialRutinas/{docId}   { allow read, write: if isOwner(uid); }
      match /registrosSalud/{docId}     { allow read, write: if isOwner(uid); }
      match /historialCardio/{docId}    { allow read, write: if isOwner(uid); }
      match /medidas/{docId}            { allow read, write: if isOwner(uid); }
      match /miRutina/{docId}           { allow read, write: if isOwner(uid); }
    }

    // ── Máquinas ─────────────────────────────────────────────────
    match /maquinas/{maquinaId} {
      allow read: if true;
      allow write: if isAdmin();

      match /ejercicios/{ejercicioId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── Rutinas ──────────────────────────────────────────────────
    match /rutinas/{grupoId} {
      allow read: if true;
      allow write: if isAdmin();

      match /dias/{diaId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ── Contenido educativo (Guía) ────────────────────────────────
    match /contenidoEducativo/{artId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Contenido de páginas (inicio, cardio, etc.) ───────────────
    match /contenidoApp/{pagina} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Avisos ───────────────────────────────────────────────────
    match /avisos/{avisoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Reportes ─────────────────────────────────────────────────
    match /reportes/{reporteId} {
      allow create: if isAuth();
      allow read:   if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Solicitudes de rutina ─────────────────────────────────────
    match /solicitudesRutina/{solId} {
      allow create: if isAuth();
      allow read:   if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin();
    }
  }
}
